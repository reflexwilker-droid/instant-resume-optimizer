# Instant Resume Optimizer - Environment Configuration

Copy this file to .env and fill in your values.

# Required
OPENROUTER_API_KEY=sk-or-v1-...

# Flask
SECRET_KEY=generate-a-random-32-char-string-for-sessions

# Optional: Stripe Payment Links (set up in Stripe Dashboard)
STRIPE_PAYMENT_LINK_SINGLE=https://buy.stripe.com/...
STRIPE_PAYMENT_LINK_MONTHLY=https://buy.stripe.com/...
STRIPE_PAYMENT_LINK_ANNUAL=https://buy.stripe.com/...

# Optional: Admin password for /admin stats
ADMIN_PASSWORD=your-secure-admin-password

# Optional: OpenRouter model override (default: openrouter/stepfun/step-3.5-flash:free)
OPENROUTER_MODEL=openrouter/anthropic/claude-3-haiku:free

# Note: No database configuration needed — SQLite file (usage.db) created automatically.
